{
  "name": "field-demo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve playground",
    "build": "ng build playground",
    "build:all": "ng build field-ui && ng build playground",
    "deploy:gh-pages": "ng build playground --base-href /field-ui-test/ && gh-pages -d dist/playground/browser --nojekyll",
    "watch": "ng build playground --watch --configuration development",
    "test": "ng test playground",
    "test:lib": "ng test field-ui",
    "test:all": "ng test field-ui && ng test playground",
    "format": "prettier --write \"projects/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss}\"",
    "lint": "eslint projects/"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.3.1",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "eslint": "^10.1.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.8"
  }
}
